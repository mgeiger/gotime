# -----------------------------------------------------------------------------
# gotime example environment. Copy to `.env` for local development.
# NEVER commit a real `.env`. For CI integration tests, keys come from GitHub
# Actions secrets. Production deploys ship their own `.env`.
# -----------------------------------------------------------------------------

# Database (override for Postgres when available)
GOTIME_DATABASE_URL=sqlite:///./gotime.db

# Persist raw provider JSON to `trip_api_logs` (default: false).
# Several providers' Terms of Service restrict or forbid long-term storage of
# their raw responses (Mapbox/Bing forbid; Google ~30 days; Azure ~6 months).
# Only flip this on after verifying your vendor plan allows it. See
# `docs/compliance.md` for the per-provider breakdown and a suggested
# retention policy. Normalized `trips` rows are always written regardless.
GOTIME_STORE_RAW_RESPONSES=false

# ---------- Provider API Keys ----------
# Primary key is active; duplicates discovered in legacy code are listed as
# commented-out lines so operators can rotate to a backup if the primary is
# revoked. Replace placeholders with your real keys.

# Google Maps Platform (Directions API)
# Docs:    https://developers.google.com/maps/documentation/directions
GOOGLE_MAPS_API_KEY=your-google-maps-key
# GOOGLE_MAPS_API_KEY=legacy-key-1
# GOOGLE_MAPS_API_KEY=legacy-key-2
# Alternate Google key discovered in legacy `go/runner.py` copies. Only set if
# you want to failover from the primary above without swapping env vars.
# GOOGLE_MAPS_API_KEY_ALT=your-second-google-maps-key

# Bing Maps (Routes API)
# Docs:    https://learn.microsoft.com/bingmaps/rest-services/routes/
BING_MAPS_API_KEY=your-bing-maps-key

# TomTom Routing API
# Docs:    https://developer.tomtom.com/routing-api/documentation
TOMTOM_API_KEY=your-tomtom-key

# HERE Routing v8
# Docs:    https://www.here.com/docs/bundle/routing-api-v8-api-reference
HERE_API_KEY=your-here-key
# Legacy HERE v7.2 auth (app_id + app_code). Only populate these if you still
# call the retired `route.cit.api.here.com` endpoint (seen in `go/runner.py`).
# HERE_APP_ID=your-here-app-id
# HERE_APP_CODE=your-here-app-code
# HERE_APP_ID_LEGACY1=your-older-here-app-id
# HERE_APP_CODE_LEGACY1=your-older-here-app-code

# MapQuest Directions API
# Docs:    https://developer.mapquest.com/documentation/directions-api/
MAPQUEST_API_KEY=your-mapquest-key

# Mapbox Directions API
# Docs:    https://docs.mapbox.com/api/navigation/directions/
MAPBOX_API_KEY=your-mapbox-token

# Azure Maps Route service
# Docs:    https://learn.microsoft.com/rest/api/maps/route
AZURE_MAPS_API_KEY=your-azure-maps-key
# Azure subscription keys are issued in pairs. Keep the backup handy for
# zero-downtime rotation.
# AZURE_MAPS_API_KEY_SECONDARY=your-azure-maps-secondary-key

# Stadia Maps Routing
# Docs:    https://docs.stadiamaps.com/api-reference/#tag/Routing-V1
# STADIA_API_KEY=your-stadia-key
